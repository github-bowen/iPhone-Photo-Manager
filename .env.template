# App language: "zh" for Chinese, "en" for English
APP_LANGUAGE=en

# UI theme: "light" or "dark"
APP_THEME=light

# Path to the photos directory (relative to project root, or absolute)
PHOTOS_DIR=photos

# Server configuration
SERVER_HOST=127.0.0.1
SERVER_PORT=8000

# Whether to run a full scan on every startup
# Set to False after the initial import to speed up restarts
SCAN_ON_STARTUP=True

# UI Settings
# Whether to load the original high-resolution image directly when opening a photo
LOAD_ORIGINAL_ON_CLICK=false

# Database and thumbnail storage paths (relative to project root, or absolute)
DB_PATH=data/photos.db
THUMBNAIL_DIR=data/thumbnails

# Thumbnail settings
THUMBNAIL_QUALITY=80
THUMBNAIL_SMALL_SIZE=200
THUMBNAIL_MEDIUM_SIZE=800

# HTTP cache max age (seconds) for static files and thumbnails (e.g. 86400 = 1 day, 0 = no cache)
HTTP_CACHE_MAX_AGE=86400
